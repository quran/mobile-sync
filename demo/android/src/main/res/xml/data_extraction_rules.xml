<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/quran_mobile_sync_settings.preferences_pb"/>
        <exclude domain="file" path="datastore/org.publicvalue.multiplatform.oidc.tokenstore.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/quran_mobile_sync_settings.preferences_pb"/>
        <exclude domain="file" path="datastore/org.publicvalue.multiplatform.oidc.tokenstore.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>
