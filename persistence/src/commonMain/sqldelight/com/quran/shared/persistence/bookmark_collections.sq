CREATE TABLE IF NOT EXISTS bookmark_collection(
  local_id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  bookmark_local_id INTEGER NOT NULL,
  collection_local_id INTEGER NOT NULL,
  is_active INTEGER NOT NULL DEFAULT 1,
  pending_op TEXT,
  pending_version INTEGER NOT NULL DEFAULT 0,
  last_synced_bookmark_remote_id TEXT,
  last_synced_collection_remote_id TEXT,
  created_at INTEGER DEFAULT (CAST(strftime('%s', 'now') AS INTEGER) * 1000) NOT NULL,
  modified_at INTEGER DEFAULT (CAST(strftime('%s', 'now') AS INTEGER) * 1000) NOT NULL,
  CHECK (is_active IN (0, 1)),
  CHECK (pending_op IS NULL OR pending_op IN ('CREATED', 'DELETED')),
  UNIQUE(bookmark_local_id, collection_local_id),
  FOREIGN KEY(bookmark_local_id) REFERENCES bookmark(local_id),
  FOREIGN KEY(collection_local_id) REFERENCES collection(local_id)
);

CREATE INDEX IF NOT EXISTS bookmark_collection_active_created_idx
ON bookmark_collection(is_active, created_at DESC);
CREATE INDEX IF NOT EXISTS bookmark_collection_collection_active_created_idx
ON bookmark_collection(collection_local_id, is_active, created_at DESC);
CREATE INDEX IF NOT EXISTS bookmark_collection_pending_idx
ON bookmark_collection(pending_op, modified_at DESC);
CREATE INDEX IF NOT EXISTS bookmark_collection_snapshots_idx
ON bookmark_collection(last_synced_collection_remote_id, last_synced_bookmark_remote_id);

getCollectionBookmarks:
  SELECT * FROM bookmark_collection WHERE is_active = 1 ORDER BY created_at DESC;

countAll:
  SELECT COUNT(*) FROM bookmark_collection;

changedRowCount:
  SELECT changes();

countActiveForBookmark:
  SELECT COUNT(*) FROM bookmark_collection
  WHERE bookmark_local_id = ? AND is_active = 1;

countRetainedForBookmark:
  SELECT COUNT(*) FROM bookmark_collection
  WHERE bookmark_local_id = ?
    AND (
      is_active = 1
      OR pending_op IS NOT NULL
      OR (
        (
          last_synced_bookmark_remote_id IS NOT NULL
          OR last_synced_collection_remote_id IS NOT NULL
        )
        AND NOT EXISTS (
          SELECT 1 FROM bookmark b
          WHERE b.local_id = bookmark_collection.bookmark_local_id
            AND b.deleted = 1
            AND b.is_reading = 0
            AND b.is_in_default_collection = 0
            AND b.bookmark_pending_op IS NULL
            AND b.reading_pending_op IS NULL
            AND b.default_pending_op IS NULL
        )
      )
    );

getCollectionBookmarksForCollection:
  SELECT * FROM bookmark_collection
  WHERE collection_local_id = ? AND is_active = 1
  ORDER BY created_at DESC;

getCollectionBookmarksWithDetails:
  SELECT
    bc.local_id,
    bc.bookmark_local_id,
    bc.collection_local_id,
    bc.is_active,
    bc.pending_op,
    bc.pending_version,
    bc.last_synced_bookmark_remote_id,
    bc.last_synced_collection_remote_id,
    bc.created_at,
    bc.modified_at,
    c.remote_id AS collection_remote_id,
    c.name AS collection_name,
    b.remote_id AS bookmark_remote_id,
    b.bookmark_type AS bookmark_type,
    b.sura AS sura,
    b.ayah AS ayah,
    b.page AS page
  FROM bookmark_collection bc
  JOIN collection c ON c.local_id = bc.collection_local_id
  JOIN bookmark b ON b.local_id = bc.bookmark_local_id
  WHERE bc.is_active = 1
    AND b.deleted = 0
    AND c.deleted = 0
  ORDER BY bc.created_at DESC;

getCollectionBookmarksForCollectionWithDetails:
  SELECT
    bc.local_id,
    bc.bookmark_local_id,
    bc.collection_local_id,
    bc.is_active,
    bc.pending_op,
    bc.pending_version,
    bc.last_synced_bookmark_remote_id,
    bc.last_synced_collection_remote_id,
    bc.created_at,
    bc.modified_at,
    c.remote_id AS collection_remote_id,
    c.name AS collection_name,
    b.remote_id AS bookmark_remote_id,
    b.bookmark_type AS bookmark_type,
    b.sura AS sura,
    b.ayah AS ayah,
    b.page AS page
  FROM bookmark_collection bc
  JOIN collection c ON c.local_id = bc.collection_local_id
  JOIN bookmark b ON b.local_id = bc.bookmark_local_id
  WHERE bc.collection_local_id = :collection_local_id
    AND bc.is_active = 1
    AND b.deleted = 0
    AND c.deleted = 0
  ORDER BY bc.created_at DESC;

getUnsyncedCollectionBookmarksWithDetails:
  SELECT
    bc.local_id,
    bc.bookmark_local_id,
    bc.collection_local_id,
    bc.is_active,
    bc.pending_op,
    bc.pending_version,
    bc.last_synced_bookmark_remote_id,
    bc.last_synced_collection_remote_id,
    bc.created_at,
    bc.modified_at,
    c.remote_id AS collection_remote_id,
    c.name AS collection_name,
    b.remote_id AS bookmark_remote_id,
    b.bookmark_type AS bookmark_type,
    b.sura AS sura,
    b.ayah AS ayah,
    b.page AS page
  FROM bookmark_collection bc
  JOIN collection c ON c.local_id = bc.collection_local_id
  JOIN bookmark b ON b.local_id = bc.bookmark_local_id
  WHERE bc.pending_op IS NOT NULL
    AND (
      (bc.pending_op = 'CREATED' AND bc.is_active = 1 AND c.deleted = 0 AND c.remote_id IS NOT NULL AND c.remote_id != '')
      OR
      (bc.pending_op = 'DELETED' AND bc.last_synced_collection_remote_id IS NOT NULL AND bc.last_synced_bookmark_remote_id IS NOT NULL)
    )
  ORDER BY bc.modified_at DESC;

getCollectionBookmarkFor:
  SELECT * FROM bookmark_collection
  WHERE bookmark_local_id = ? AND collection_local_id = ? LIMIT 1;

getCollectionBookmarkByLocalId:
  SELECT * FROM bookmark_collection
  WHERE local_id = ? LIMIT 1;

getBookmarkLocalIdBySnapshot:
  SELECT bookmark_local_id FROM bookmark_collection
  WHERE last_synced_bookmark_remote_id = :bookmark_remote_id
    AND last_synced_collection_remote_id = :collection_remote_id
  LIMIT 1;

getBookmarkLocalIdByCurrentRemoteIds:
  SELECT bc.bookmark_local_id FROM bookmark_collection bc
  JOIN collection c ON c.local_id = bc.collection_local_id
  JOIN bookmark b ON b.local_id = bc.bookmark_local_id
  WHERE c.remote_id = :collection_remote_id
    AND b.remote_id = :bookmark_remote_id
    AND bc.is_active = 1
  LIMIT 1;

getBookmarkLocalIdsForCollectionRemoteId:
  SELECT bc.bookmark_local_id FROM bookmark_collection bc
  JOIN collection c ON c.local_id = bc.collection_local_id
  WHERE c.remote_id = :collection_remote_id;

getCollectionBookmarkWithDetailsByRemoteId:
  SELECT
    bc.local_id,
    bc.bookmark_local_id,
    bc.collection_local_id,
    bc.is_active,
    bc.pending_op,
    bc.pending_version,
    bc.last_synced_bookmark_remote_id,
    bc.last_synced_collection_remote_id,
    bc.created_at,
    bc.modified_at,
    c.remote_id AS collection_remote_id,
    c.name AS collection_name,
    b.remote_id AS bookmark_remote_id,
    b.bookmark_type AS bookmark_type,
    b.sura AS sura,
    b.ayah AS ayah,
    b.page AS page
  FROM bookmark_collection bc
  JOIN collection c ON c.local_id = bc.collection_local_id
  JOIN bookmark b ON b.local_id = bc.bookmark_local_id
  WHERE (
      bc.last_synced_collection_remote_id || '-' || bc.last_synced_bookmark_remote_id = :remote_id
      OR (bc.is_active = 1 AND c.remote_id || '-' || b.remote_id = :remote_id)
    )
  LIMIT 1;

addBookmarkToCollection {
  INSERT OR IGNORE INTO bookmark_collection (
    bookmark_local_id,
    collection_local_id,
    is_active,
    pending_op,
    pending_version,
    created_at,
    modified_at
  )
  VALUES (
    :bookmark_local_id,
    :collection_local_id,
    1,
    'CREATED',
    0,
    COALESCE(:timestamp, CAST(strftime('%s', 'now') AS INTEGER) * 1000),
    COALESCE(:timestamp, CAST(strftime('%s', 'now') AS INTEGER) * 1000)
  );
  UPDATE bookmark_collection
  SET is_active = 1,
    pending_op = CASE
      WHEN last_synced_bookmark_remote_id = (
          SELECT remote_id FROM bookmark WHERE local_id = :bookmark_local_id
        )
        AND last_synced_collection_remote_id = (
          SELECT remote_id FROM collection WHERE local_id = :collection_local_id
        )
        AND (
          is_active = 1
          OR pending_op = 'DELETED'
        ) THEN NULL
      ELSE 'CREATED'
    END,
    pending_version = pending_version + 1,
    modified_at = COALESCE(:timestamp, CAST(strftime('%s', 'now') AS INTEGER) * 1000)
  WHERE bookmark_local_id = :bookmark_local_id
    AND collection_local_id = :collection_local_id;
}

insertImportedBookmarkCollection {
  INSERT OR IGNORE INTO bookmark_collection (
    bookmark_local_id,
    collection_local_id,
    is_active,
    pending_op,
    pending_version,
    created_at,
    modified_at
  )
  VALUES (
    :bookmark_local_id,
    :collection_local_id,
    1,
    'CREATED',
    1,
    :created_at,
    :modified_at
  );
  UPDATE bookmark_collection
  SET is_active = 1,
    pending_op = 'CREATED',
    pending_version = CASE WHEN pending_op = 'CREATED' THEN pending_version ELSE pending_version + 1 END,
    modified_at = :modified_at
  WHERE bookmark_local_id = :bookmark_local_id
    AND collection_local_id = :collection_local_id;
}

markBookmarkCollectionDeleted {
  DELETE FROM bookmark_collection
  WHERE bookmark_local_id = :bookmark_local_id
    AND collection_local_id = :collection_local_id
    AND last_synced_bookmark_remote_id IS NULL
    AND last_synced_collection_remote_id IS NULL
    AND (pending_op IS NULL OR pending_op != 'CREATED' OR pending_version <= 1);
  UPDATE bookmark_collection
  SET is_active = 0,
    pending_op = 'DELETED',
    pending_version = CASE WHEN pending_op = 'DELETED' THEN pending_version ELSE pending_version + 1 END,
    modified_at = COALESCE(:timestamp, CAST(strftime('%s', 'now') AS INTEGER) * 1000)
  WHERE bookmark_local_id = :bookmark_local_id
    AND collection_local_id = :collection_local_id;
}

markBookmarkCollectionsDeletedForBookmark {
  DELETE FROM bookmark_collection
  WHERE bookmark_local_id = :bookmark_local_id
    AND last_synced_bookmark_remote_id IS NULL
    AND last_synced_collection_remote_id IS NULL
    AND (pending_op IS NULL OR pending_op != 'CREATED' OR pending_version <= 1);
  UPDATE bookmark_collection
  SET is_active = 0,
    pending_op = 'DELETED',
    pending_version = CASE WHEN pending_op = 'DELETED' THEN pending_version ELSE pending_version + 1 END,
    modified_at = COALESCE(:timestamp, CAST(strftime('%s', 'now') AS INTEGER) * 1000)
  WHERE bookmark_local_id = :bookmark_local_id;
}

clearLocalMutationFor {
  UPDATE bookmark_collection
  SET pending_op = NULL,
    last_synced_bookmark_remote_id = COALESCE(:bookmark_remote_id, last_synced_bookmark_remote_id),
    last_synced_collection_remote_id = COALESCE(:collection_remote_id, last_synced_collection_remote_id),
    modified_at = :modified_at
  WHERE local_id = :id
    AND pending_op = :pending_op
    AND pending_version = :pending_version;
}

bindRemoteSnapshotForCreatedAck:
  UPDATE bookmark_collection
  SET last_synced_bookmark_remote_id = COALESCE(:bookmark_remote_id, last_synced_bookmark_remote_id),
    last_synced_collection_remote_id = COALESCE(:collection_remote_id, last_synced_collection_remote_id),
    modified_at = :modified_at
  WHERE local_id = :id
    AND is_active = 0
    AND pending_op = 'DELETED';

markBookmarkCollectionForRecreation:
  UPDATE bookmark_collection
  SET pending_op = 'CREATED',
    pending_version = pending_version + 1,
    modified_at = :modified_at
  WHERE local_id = :id
    AND is_active = 1
    AND pending_op IS NULL;

markCreatedMutationInFlight:
  UPDATE bookmark_collection
  SET pending_version = pending_version + 1
  WHERE local_id = :id
    AND pending_op = 'CREATED'
    AND pending_version = :pending_version;

rollbackActiveCreatedMutationInFlight:
  UPDATE bookmark_collection
  SET pending_version = :pending_version
  WHERE local_id = :id
    AND is_active = 1
    AND pending_op = 'CREATED'
    AND pending_version = :marked_pending_version;

deleteCanceledCreatedMutationInFlight:
  DELETE FROM bookmark_collection
  WHERE local_id = :id
    AND is_active = 0
    AND pending_op = 'DELETED'
    AND pending_version = :canceled_pending_version
    AND last_synced_bookmark_remote_id IS NULL
    AND last_synced_collection_remote_id IS NULL;

persistRemoteBookmarkCollection {
  INSERT OR IGNORE INTO bookmark_collection (
    bookmark_local_id,
    collection_local_id,
    is_active,
    pending_op,
    pending_version,
    last_synced_bookmark_remote_id,
    last_synced_collection_remote_id,
    created_at,
    modified_at
  )
  VALUES (
    :bookmark_local_id,
    :collection_local_id,
    1,
    NULL,
    0,
    :bookmark_remote_id,
    :collection_remote_id,
    :created_at,
    :modified_at
  );
  UPDATE bookmark_collection
  SET is_active = CASE
      WHEN is_active = 0 AND pending_op = 'DELETED' THEN is_active
      ELSE 1
    END,
    last_synced_bookmark_remote_id = :bookmark_remote_id,
    last_synced_collection_remote_id = :collection_remote_id,
    modified_at = :modified_at
  WHERE bookmark_local_id = :bookmark_local_id
    AND collection_local_id = :collection_local_id;
}

deleteRemoteBookmarkCollectionBySnapshot {
  UPDATE bookmark_collection
  SET last_synced_bookmark_remote_id = NULL,
    last_synced_collection_remote_id = NULL,
    modified_at = CAST(strftime('%s', 'now') AS INTEGER) * 1000
  WHERE last_synced_bookmark_remote_id = :bookmark_remote_id
    AND last_synced_collection_remote_id = :collection_remote_id
    AND is_active = 1
    AND pending_op = 'CREATED';
  DELETE FROM bookmark_collection
  WHERE last_synced_bookmark_remote_id = :bookmark_remote_id
    AND last_synced_collection_remote_id = :collection_remote_id;
}

deleteBookmarkCollectionByCurrentRemoteIds:
  DELETE FROM bookmark_collection
  WHERE local_id IN (
    SELECT bc.local_id FROM bookmark_collection bc
    JOIN collection c ON c.local_id = bc.collection_local_id
    JOIN bookmark b ON b.local_id = bc.bookmark_local_id
    WHERE c.remote_id = :collection_remote_id
      AND b.remote_id = :bookmark_remote_id
      AND bc.is_active = 1
  );

deleteUnsyncedBookmarkCollectionByLocalIds:
  DELETE FROM bookmark_collection
  WHERE bookmark_local_id = :bookmark_local_id
    AND collection_local_id = :collection_local_id
    AND (
      last_synced_bookmark_remote_id IS NULL
      OR last_synced_collection_remote_id IS NULL
    );

markActiveLinksWithChangedSnapshots:
  UPDATE bookmark_collection
  SET pending_op = 'CREATED',
    pending_version = pending_version + 1,
    modified_at = CAST(strftime('%s', 'now') AS INTEGER) * 1000
  WHERE is_active = 1
    AND pending_op IS NULL
    AND (
      last_synced_bookmark_remote_id IS NOT NULL
      OR last_synced_collection_remote_id IS NOT NULL
    )
    AND EXISTS (
      SELECT 1 FROM bookmark b
      JOIN collection c ON c.local_id = bookmark_collection.collection_local_id
      WHERE b.local_id = bookmark_collection.bookmark_local_id
        AND b.deleted = 0
        AND c.deleted = 0
        AND b.remote_id IS NOT NULL
        AND c.remote_id IS NOT NULL
        AND (
          bookmark_collection.last_synced_bookmark_remote_id != b.remote_id
          OR bookmark_collection.last_synced_collection_remote_id != c.remote_id
        )
    );

deleteInactiveClearedLinks:
  DELETE FROM bookmark_collection
  WHERE is_active = 0
    AND pending_op IS NULL
    AND (
      (
        last_synced_bookmark_remote_id IS NULL
        AND last_synced_collection_remote_id IS NULL
      )
      OR NOT EXISTS (
        SELECT 1 FROM bookmark b
        WHERE b.local_id = bookmark_collection.bookmark_local_id
      )
      OR EXISTS (
        SELECT 1 FROM bookmark b
        WHERE b.local_id = bookmark_collection.bookmark_local_id
          AND b.deleted = 1
          AND b.is_reading = 0
          AND b.is_in_default_collection = 0
          AND b.bookmark_pending_op IS NULL
          AND b.reading_pending_op IS NULL
          AND b.default_pending_op IS NULL
      )
    );

deleteRetiredInactiveClearedLinksForBookmark:
  DELETE FROM bookmark_collection
  WHERE bookmark_local_id = :bookmark_local_id
    AND is_active = 0
    AND pending_op IS NULL
    AND EXISTS (
      SELECT 1 FROM bookmark b
      WHERE b.local_id = :bookmark_local_id
        AND b.deleted = 1
        AND b.is_reading = 0
        AND b.is_in_default_collection = 0
        AND b.bookmark_pending_op IS NULL
        AND b.reading_pending_op IS NULL
        AND b.default_pending_op IS NULL
    );

deleteLinksForInactiveParents:
  DELETE FROM bookmark_collection
  WHERE last_synced_bookmark_remote_id IS NULL
    AND last_synced_collection_remote_id IS NULL
    AND (pending_op IS NULL OR pending_op != 'DELETED')
    AND (
      NOT EXISTS (SELECT 1 FROM bookmark b WHERE b.local_id = bookmark_collection.bookmark_local_id AND b.deleted = 0)
      OR NOT EXISTS (SELECT 1 FROM collection c WHERE c.local_id = bookmark_collection.collection_local_id AND c.deleted = 0)
    );

markSyncedLinksForInactiveParents:
  UPDATE bookmark_collection
  SET is_active = 0,
    pending_op = 'DELETED',
    pending_version = CASE WHEN pending_op = 'DELETED' THEN pending_version ELSE pending_version + 1 END,
    modified_at = CAST(strftime('%s', 'now') AS INTEGER) * 1000
  WHERE (
      last_synced_bookmark_remote_id IS NOT NULL
      OR last_synced_collection_remote_id IS NOT NULL
    )
    AND (
      NOT EXISTS (SELECT 1 FROM bookmark b WHERE b.local_id = bookmark_collection.bookmark_local_id AND b.deleted = 0)
      OR NOT EXISTS (SELECT 1 FROM collection c WHERE c.local_id = bookmark_collection.collection_local_id AND c.deleted = 0)
    );

deleteUnsyncedBookmarkCollections:
  DELETE FROM bookmark_collection
  WHERE pending_op = 'CREATED'
    AND last_synced_bookmark_remote_id IS NULL
    AND last_synced_collection_remote_id IS NULL;

markUnsyncedBookmarkCollectionsDeletedForImport:
  UPDATE bookmark_collection
  SET is_active = 0,
    pending_op = 'DELETED',
    pending_version = CASE WHEN pending_op = 'DELETED' THEN pending_version ELSE pending_version + 1 END,
    modified_at = :modified_at
  WHERE pending_op = 'CREATED'
    AND last_synced_bookmark_remote_id IS NULL
    AND last_synced_collection_remote_id IS NULL;

markRemoteBookmarkCollectionsDeleted:
  UPDATE bookmark_collection
  SET is_active = 0,
    pending_op = 'DELETED',
    pending_version = CASE WHEN pending_op = 'DELETED' THEN pending_version ELSE pending_version + 1 END,
    modified_at = :modified_at
  WHERE last_synced_bookmark_remote_id IS NOT NULL
    OR last_synced_collection_remote_id IS NOT NULL;

checkRemoteIDsExistence:
  SELECT last_synced_collection_remote_id || '-' || last_synced_bookmark_remote_id AS remote_id
  FROM bookmark_collection
  WHERE last_synced_collection_remote_id || '-' || last_synced_bookmark_remote_id IN :queried_ids
  UNION
  SELECT c.remote_id || '-' || b.remote_id AS remote_id
  FROM bookmark_collection bc
  JOIN collection c ON c.local_id = bc.collection_local_id
  JOIN bookmark b ON b.local_id = bc.bookmark_local_id
  WHERE bc.is_active = 1
    AND c.remote_id IS NOT NULL
    AND b.remote_id IS NOT NULL
    AND c.remote_id || '-' || b.remote_id IN :queried_ids;

deleteAll:
  DELETE FROM bookmark_collection;
